class AppSecrets {
  AppSecrets._();

  // رابط Google Apps Script الخاص بك
  // مثال: https://script.google.com/macros/s/AKfycby.../exec
  static const String gasBaseUrl = 'REPLACE_WITH_GAS_URL';

  // المفتاح السري المشترك بين Flutter والـ GAS
  static const String gasSecretKey = 'REPLACE_WITH_SECRET_KEY';

  // مفتاح Gemini API من Google AI Studio
  // https://aistudio.google.com/app/apikey
  static const String geminiApiKey = 'REPLACE_WITH_GEMINI_KEY';
}
